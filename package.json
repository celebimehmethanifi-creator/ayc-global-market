{
    "name":  "neura",
    "version":  "0.1.0",
    "private":  true,
    "packageManager": "pnpm@11.1.3",
    "scripts":  {
                    "dev":  "turbo run dev",
                    "build":  "turbo run build",
                    "lint":  "turbo run lint --filter=neura-web",
                    "type-check":  "turbo run type-check --filter=neura-web",
                    "test:browser": "playwright test",
                    "test:browserstack": "playwright test -c playwright.browserstack.config.ts",
                    "test:browser:install": "playwright install chromium",
                    "db:migrate":  "cd infra && python -m alembic upgrade head",
                    "db:seed":  "python scripts/seed_assets.py"
                },
    "devDependencies":  {
                            "turbo":  "^2.0.0",
                            "@playwright/test": "1.56.1",
                            "browserstack-local": "^1.5.6"
                        },
    "engines":  {
                    "node":  ">=20",
                    "pnpm":  ">=9"
                }
}
