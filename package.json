{
    "name":  "neura",
    "version":  "0.1.0",
    "private":  true,
    "scripts":  {
                    "dev":  "turbo run dev",
                    "build":  "turbo run build",
                    "lint":  "turbo run lint",
                    "type-check":  "turbo run type-check",
                    "test:browser": "playwright test",
                    "test:browser:install": "playwright install chromium",
                    "db:migrate":  "cd infra && python -m alembic upgrade head",
                    "db:seed":  "python scripts/seed_assets.py"
                },
    "devDependencies":  {
                            "turbo":  "^2.0.0",
                            "@playwright/test": "^1.56.1"
                        },
    "engines":  {
                    "node":  ">=20",
                    "pnpm":  ">=9"
                },
    "pnpm":  {
                 "onlyBuiltDependencies":  [
                                               "unrs-resolver"
                                           ]
             }
}
