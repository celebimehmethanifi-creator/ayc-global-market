# Core runtime
ENVIRONMENT=<development|staging|production>
DATABASE_URL=<postgres-or-sqlite-url>
REDIS_URL=<redis-url>

# Web auth and exchange security (required in production)
JWT_SECRET=<min-32-char-random-secret>
EXCHANGE_CREDENTIALS_KEY=<min-32-char-random-secret>

# Gateway auth security (required in production)
SECRET_KEY=<min-32-char-random-secret>
CORS_ORIGINS=<comma-separated-allowed-origins>

# Frontend
# Leave empty for production web deploy when using same-origin Next API routes.
NEXT_PUBLIC_API_URL=<optional-public-api-base-url-or-empty>
NEXT_PUBLIC_SITE_URL=<https://aycmarket.com>
APP_ALIAS_REDIRECT=<0-or-1>
NEXT_PUBLIC_FINNHUB_KEY=<optional-public-finnhub-key>

# AI providers
OPENAI_API_KEY=<openai-api-key>
ANTHROPIC_API_KEY=<anthropic-api-key>
GEMINI_API_KEY=<gemini-api-key>

# Market data providers
COINGECKO_API_KEY=<coingecko-api-key>
FINNHUB_API_KEY=<finnhub-api-key>
TWELVEDATA_API_KEY=<twelvedata-api-key>
ALPHAVANTAGE_API_KEY=<alphavantage-api-key>

# Billing providers
STRIPE_SECRET_KEY=<stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<stripe-webhook-secret>
STRIPE_PRICE_PRO=<stripe-price-id-pro>
STRIPE_PRICE_ELITE=<stripe-price-id-elite>
LEMON_API_KEY=<lemon-api-key>
LEMON_WEBHOOK_SECRET=<lemon-webhook-secret>
LEMON_STORE_ID=<lemon-store-id>
LEMON_PRO_VARIANT_ID=<lemon-variant-id-pro>
LEMON_ELITE_VARIANT_ID=<lemon-variant-id-elite>
